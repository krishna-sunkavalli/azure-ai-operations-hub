{"version":"Notebook/1.0","items":[{"type":1,"content":{"json":"# Azure AI Operations Hub\n### Single Pane of Glass — Azure AI & Cognitive Services\n\nMonitors `Microsoft.CognitiveServices/accounts` and `Microsoft.CognitiveServices/accounts/projects` (Azure AI Foundry). Select your scope below to begin.\n\n---"},"name":"header"},{"type":9,"content":{"version":"KqlParameterItem/1.0","parameters":[{"id":"p-subscription","version":"KqlParameterItem/1.0","name":"Subscription","type":6,"isRequired":false,"multiSelect":true,"value":["value::all"],"typeSettings":{"additionalResourceOptions":["value::all"],"includeAll":true},"label":"Subscription"},{"id":"p-resourcegroup","version":"KqlParameterItem/1.0","name":"ResourceGroup","type":2,"isRequired":false,"multiSelect":true,"query":"Resources\n| where type =~ 'microsoft.cognitiveservices/accounts'\n| summarize by resourceGroup\n| project value = resourceGroup, label = resourceGroup\n| order by label asc","queryType":1,"resourceType":"microsoft.resources/subscriptions","crossComponentResources":["{Subscription}"],"value":["value::all"],"typeSettings":{"additionalResourceOptions":["value::all"]},"label":"Resource Group"},{"id":"p-resource","version":"KqlParameterItem/1.0","name":"CogServicesResource","type":5,"isRequired":false,"multiSelect":true,"query":"Resources\n| where type =~ 'microsoft.cognitiveservices/accounts'\n| where array_length(todynamic('{ResourceGroup}')) == 0 or resourceGroup in~ (todynamic('{ResourceGroup}'))\n| project value = id, label = name, group = resourceGroup\n| order by label asc","queryType":1,"resourceType":"microsoft.resources/subscriptions","crossComponentResources":["{Subscription}"],"value":["value::all"],"typeSettings":{"additionalResourceOptions":["value::all"],"showDefault":false},"label":"AI / Cognitive Services Resource"},{"id":"p-law","version":"KqlParameterItem/1.0","name":"LogAnalyticsWorkspace","type":5,"isRequired":false,"multiSelect":true,"query":"Resources\n| where type =~ 'microsoft.operationalinsights/workspaces'\n| project value = id, label = name, group = resourceGroup\n| order by label asc","queryType":1,"resourceType":"microsoft.resources/subscriptions","crossComponentResources":["{Subscription}"],"value":["value::all"],"typeSettings":{"additionalResourceOptions":["value::all"],"showDefault":false},"label":"Log Analytics Workspace"},{"id":"p-servicetier","version":"KqlParameterItem/1.0","name":"ServiceTier","type":2,"isRequired":false,"multiSelect":false,"value":"All","typeSettings":{"additionalResourceOptions":[]},"jsonData":"[{\"value\": \"All\", \"label\": \"All\"}, {\"value\": \"PTU\", \"label\": \"PTU\"}, {\"value\": \"PTU-Managed\", \"label\": \"PTU-Managed\"}, {\"value\": \"Pay-as-you-go\", \"label\": \"Pay-as-you-go\"}]","label":"Service Tier"},{"id":"p-timerange","version":"KqlParameterItem/1.0","name":"TimeRange","type":4,"value":{"durationMs":604800000},"typeSettings":{"selectableValues":[{"durationMs":3600000},{"durationMs":14400000},{"durationMs":43200000},{"durationMs":86400000},{"durationMs":259200000},{"durationMs":604800000},{"durationMs":2592000000}]},"label":"Time Range"},{"id":"p-tab","version":"KqlParameterItem/1.0","name":"tab","type":1,"isRequired":true,"value":"overview","isHiddenWhenLocked":true,"label":"tab"},{"id":"p-foundry-resources","version":"KqlParameterItem/1.0","name":"FoundryProjectResources","type":5,"isRequired":false,"multiSelect":true,"query":"Resources\n| where type =~ 'microsoft.cognitiveservices/accounts/projects'\n| where array_length(todynamic('{ResourceGroup}')) == 0 or resourceGroup in~ (todynamic('{ResourceGroup}'))\n| project value = id, label = name, group = resourceGroup\n| order by label asc","queryType":1,"resourceType":"microsoft.resources/subscriptions","crossComponentResources":["{Subscription}"],"value":["value::all"],"typeSettings":{"additionalResourceOptions":["value::all"],"showDefault":false},"label":"AI Foundry Project"}],"style":"pills","queryType":1,"resourceType":"microsoft.resources/subscriptions"},"name":"parameters"},{"type":11,"content":{"version":"LinkItem/1.0","style":"tabs","links":[{"id":"tab-overview","cellValue":"tab","linkTarget":"parameter","linkLabel":"Overview","subTarget":"overview","style":"link"},{"id":"tab-usage","cellValue":"tab","linkTarget":"parameter","linkLabel":"Token Usage","subTarget":"usage","style":"link"},{"id":"tab-latency","cellValue":"tab","linkTarget":"parameter","linkLabel":"Latency","subTarget":"latency","style":"link"},{"id":"tab-ptu","cellValue":"tab","linkTarget":"parameter","linkLabel":"PTU Utilization","subTarget":"ptu","style":"link"},{"id":"tab-safety","cellValue":"tab","linkTarget":"parameter","linkLabel":"Content Safety","subTarget":"safety","style":"link"},{"id":"tab-agents","cellValue":"tab","linkTarget":"parameter","linkLabel":"AI Agents","subTarget":"agents","style":"link"},{"id":"tab-logs","cellValue":"tab","linkTarget":"parameter","linkLabel":"Logs & Diagnostics","subTarget":"logs","style":"link"},{"id":"tab-inventory","cellValue":"tab","linkTarget":"parameter","linkLabel":"Inventory","subTarget":"inventory","style":"link"}]},"name":"tabs"},{"type":12,"content":{"version":"NotebookGroup/1.0","groupType":"editable","items":[{"type":1,"content":{"json":"## Overview\nHigh-level health and request volume across all selected Azure AI / Cognitive Services resources."},"name":"overview-header"},{"type":3,"content":{"version":"KqlItem/1.0","query":"AzureMetrics\n| where ResourceProvider =~ 'MICROSOFT.COGNITIVESERVICES'\n| where MetricName in ('AzureOpenAIRequests', 'ModelRequests')\n| summarize Total = sum(Total) by MetricName\n| project Category = case(MetricName == 'AzureOpenAIRequests', 'Azure OpenAI', MetricName == 'ModelRequests', 'Models API', MetricName), Total","size":3,"noDataMessage":"No request data in the selected time range.","title":"Request Volume by API Type","queryType":0,"resourceType":"microsoft.operationalinsights/workspaces","crossComponentResources":["{LogAnalyticsWorkspace}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","visualization":"piechart"},"conditionalVisibility":{"parameterName":"LogAnalyticsWorkspace","comparison":"isNotEqualTo","value":""},"customWidth":"40","name":"kpi-requests-piechart"},{"type":3,"content":{"version":"KqlItem/1.0","query":"Resources\n| where type =~ 'microsoft.cognitiveservices/accounts'\n| project location, ResourceName = name, Kind = tostring(kind), ResourceGroup = resourceGroup\n| summarize Count = count() by location, ResourceGroup","size":0,"title":"Resources by Region","queryType":1,"resourceType":"microsoft.resources/subscriptions","crossComponentResources":["{Subscription}"],"visualization":"map","mapSettings":{"locInfo":"AzureLoc","locInfoColumn":"location","sizeSettings":"Count","sizeAggregation":"Sum","labelSettings":"location","legendMetric":"Count","legendAggregation":"Sum","itemColorSettings":{"nodeColorField":"Count","colorAggregation":"Sum","type":"heatmap","heatmapPalette":"greenRed"}}},"customWidth":"60","name":"kpi-resource-map"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":2,"resourceType":"microsoft.cognitiveservices/accounts","metricScope":0,"resourceIds":["{CogServicesResource}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--AzureOpenAIRequests","aggregation":1,"splitBy":"StatusCode"}],"title":"Azure OpenAI Requests by Status Code","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-aoai-requests-status"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":2,"resourceType":"microsoft.cognitiveservices/accounts","metricScope":0,"resourceIds":["{CogServicesResource}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--ModelRequests","aggregation":1,"splitBy":"StatusCode"}],"title":"Models API Requests by Status Code","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-aoai-availability-deployment"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":3,"resourceType":"microsoft.cognitiveservices/accounts","metricScope":0,"resourceIds":["{CogServicesResource}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--ModelRequests","aggregation":1,"splitBy":"ModelName"}],"title":"Model Requests by Model Name","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-model-requests-model"},{"type":3,"content":{"version":"KqlItem/1.0","query":"Resources\n| where type =~ 'microsoft.cognitiveservices/accounts'\n| extend ResourceId = tolower(id)\n| join kind=leftouter (\n    Resources\n    | where type =~ 'microsoft.insights/diagnosticsettings'\n    | extend parentId = tolower(tostring(split(id, '/providers/microsoft.insights/diagnosticsettings/')[0]))\n    | summarize DiagCount = count() by parentId\n) on $left.ResourceId == $right.parentId\n| extend DiagnosticSettings = iff(isnotnull(DiagCount), 'Configured', 'Not Configured')\n| project ResourceName = name, ResourceGroup = resourceGroup, Kind = tostring(kind), SKU = tostring(sku.name), Location = location, PublicAccess = tostring(properties.publicNetworkAccess), ProvisioningState = tostring(properties.provisioningState), DiagnosticSettings\n| order by ResourceName asc","size":0,"title":"Cognitive Services Resource Inventory","queryType":1,"resourceType":"microsoft.resources/subscriptions","crossComponentResources":["{Subscription}"],"visualization":"table","gridSettings":{"formatters":[{"columnMatch":"ProvisioningState","formatter":18,"formatOptions":{"thresholdsOptions":"colors","thresholdsGrid":[{"operator":"==","thresholdValue":"Succeeded","representation":"green","text":"{0}{1}"},{"operator":"Default","thresholdValue":null,"representation":"yellow","text":"{0}{1}"}]}},{"columnMatch":"PublicAccess","formatter":18,"formatOptions":{"thresholdsOptions":"colors","thresholdsGrid":[{"operator":"==","thresholdValue":"Enabled","representation":"red","text":"{0}{1}"},{"operator":"Default","thresholdValue":null,"representation":"green","text":"{0}{1}"}]}},{"columnMatch":"DiagnosticSettings","formatter":18,"formatOptions":{"thresholdsOptions":"colors","thresholdsGrid":[{"operator":"==","thresholdValue":"Configured","representation":"green","text":"{0}{1}"},{"operator":"Default","thresholdValue":null,"representation":"red","text":"{0}{1}"}]}}],"filter":true,"sortBy":[{"itemKey":"ResourceName","sortOrder":1}]}},"name":"table-resource-inventory"}]},"conditionalVisibility":{"parameterName":"tab","comparison":"isEqualTo","value":"overview"},"name":"group-overview"},{"type":12,"content":{"version":"NotebookGroup/1.0","groupType":"editable","items":[{"type":1,"content":{"json":"## Token Usage\nTrack prompt tokens, completion tokens, cache performance, and total inference volume. Split by `ModelDeploymentName` to compare workloads across deployments."},"name":"usage-header"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":2,"resourceType":"microsoft.cognitiveservices/accounts","metricScope":0,"resourceIds":["{CogServicesResource}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--ProcessedPromptTokens","aggregation":1,"splitBy":"ModelDeploymentName"},{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--GeneratedTokens","aggregation":1,"splitBy":"ModelDeploymentName"}],"title":"Prompt vs. Completion Tokens by Deployment","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-prompt-vs-completion"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":2,"resourceType":"microsoft.cognitiveservices/accounts","metricScope":0,"resourceIds":["{CogServicesResource}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--TokenTransaction","aggregation":1,"splitBy":"ModelDeploymentName"}],"title":"Total Inference Tokens (Prompt + Completion) by Deployment","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-total-inference-tokens"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":2,"resourceType":"microsoft.cognitiveservices/accounts","metricScope":0,"resourceIds":["{CogServicesResource}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--ActiveTokens","aggregation":4,"splitBy":"ModelDeploymentName"}],"title":"Active Tokens — PTU / PTU-Managed (Excludes Cache Hits)","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-active-tokens"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":2,"resourceType":"microsoft.cognitiveservices/accounts","metricScope":0,"resourceIds":["{CogServicesResource}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--AzureOpenAIContextTokensCacheMatchRate","aggregation":4,"splitBy":"ModelDeploymentName"}],"title":"Prompt Token Cache Match Rate (%) by Deployment","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-cache-match-rate"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":3,"resourceType":"microsoft.cognitiveservices/accounts","metricScope":0,"resourceIds":["{CogServicesResource}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--AudioPromptTokens","aggregation":1,"splitBy":"ModelDeploymentName"},{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--AudioCompletionTokens","aggregation":1,"splitBy":"ModelDeploymentName"}],"title":"Audio Input + Output Tokens by Deployment","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-audio-tokens"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":2,"resourceType":"microsoft.cognitiveservices/accounts","metricScope":0,"resourceIds":["{CogServicesResource}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--RealtimeUsageTime","aggregation":1,"splitBy":"ModelDeploymentName"}],"title":"Realtime API Seconds Used by Deployment","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-realtime-usage"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":2,"resourceType":"microsoft.cognitiveservices/accounts","metricScope":0,"resourceIds":["{CogServicesResource}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--AzureOpenAITokenPerSecond","aggregation":4,"splitBy":"ModelDeploymentName"}],"title":"Tokens Per Second (Generation Speed) by Deployment","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-tps-aoai"}]},"conditionalVisibility":{"parameterName":"tab","comparison":"isEqualTo","value":"usage"},"name":"group-usage"},{"type":12,"content":{"version":"NotebookGroup/1.0","groupType":"editable","items":[{"type":1,"content":{"json":"## Latency\nAll values in milliseconds. **TTR** = Time to Response (first byte, streaming). **TTFB** = Normalized Time to First Byte (per token). **TBT** = Time Between Tokens. **TTLB** = Time to Last Byte.\n\n> For PTU deployments, correlate `NormalizedTimeToFirstToken` with PTU Utilization V2. Rising TTFB at high utilization indicates saturation."},"name":"latency-header"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":2,"resourceType":"microsoft.cognitiveservices/accounts","metricScope":0,"resourceIds":["{CogServicesResource}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--AzureOpenAITimeToResponse","aggregation":4,"splitBy":"ModelDeploymentName"},{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--AzureOpenAITimeToResponse","aggregation":3,"splitBy":"ModelDeploymentName"}],"title":"Time to Response — Azure OpenAI (Max + Avg ms) by Deployment","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-ttr-aoai"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":2,"resourceType":"microsoft.cognitiveservices/accounts","metricScope":0,"resourceIds":["{CogServicesResource}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--TimeToResponse","aggregation":4,"splitBy":"ModelDeploymentName"},{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--TimeToResponse","aggregation":3,"splitBy":"ModelDeploymentName"}],"title":"Time to Response — Models API (Max + Avg ms) by Deployment","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-ttr-models"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":2,"resourceType":"microsoft.cognitiveservices/accounts","metricScope":0,"resourceIds":["{CogServicesResource}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--AzureOpenAINormalizedTTFTInMS","aggregation":4,"splitBy":"ModelDeploymentName"},{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--AzureOpenAINormalizedTTFTInMS","aggregation":3,"splitBy":"ModelDeploymentName"}],"title":"Normalized TTFB — Azure OpenAI (Max + Avg ms/token) by Deployment","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-ttfb-aoai"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":2,"resourceType":"microsoft.cognitiveservices/accounts","metricScope":0,"resourceIds":["{CogServicesResource}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--NormalizedTimeToFirstToken","aggregation":4,"splitBy":"ModelDeploymentName"},{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--NormalizedTimeToFirstToken","aggregation":3,"splitBy":"ModelDeploymentName"}],"title":"Normalized TTFB — Models API (Max + Avg ms/token) by Deployment","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-ttfb-models"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":2,"resourceType":"microsoft.cognitiveservices/accounts","metricScope":0,"resourceIds":["{CogServicesResource}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--AzureOpenAINormalizedTBTInMS","aggregation":4,"splitBy":"ModelDeploymentName"},{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--NormalizedTimeBetweenTokens","aggregation":4,"splitBy":"ModelDeploymentName"}],"title":"Time Between Tokens — Streaming Generation Rate (Max ms)","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-tbt"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":2,"resourceType":"microsoft.cognitiveservices/accounts","metricScope":0,"resourceIds":["{CogServicesResource}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--AzureOpenAITTLTInMS","aggregation":4,"splitBy":"ModelDeploymentName"},{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--TimeToLastByte","aggregation":4,"splitBy":"ModelDeploymentName"}],"title":"Time to Last Byte — Full Response Latency (Max ms)","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-ttlb"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":2,"resourceType":"microsoft.cognitiveservices/accounts","metricScope":0,"resourceIds":["{CogServicesResource}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--TokensPerSecond","aggregation":4,"splitBy":"ModelDeploymentName"},{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--TokensPerSecond","aggregation":3,"splitBy":"ModelDeploymentName"}],"title":"Tokens Per Second — Models API (Max + Avg) by Deployment","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-tps-models"}]},"conditionalVisibility":{"parameterName":"tab","comparison":"isEqualTo","value":"latency"},"name":"group-latency"},{"type":12,"content":{"version":"NotebookGroup/1.0","groupType":"editable","items":[{"type":1,"content":{"json":"## PTU Utilization\n\n> **Note:** These metrics apply to **PTU** and **PTU-Managed** deployments only. Pay-as-you-go deployments will show no data.\n\n> **Deprecation:** `AzureOpenAIProvisionedManagedUtilization` (v1) is deprecated. This workbook uses `AzureOpenAIProvisionedManagedUtilizationV2` exclusively. When utilization reaches 100%, requests are throttled with HTTP 429.\n\n> **Tip:** Monitor `IsSpillover = true` requests to understand how often traffic is exceeding PTU capacity and overflowing to the spillover pool."},"name":"ptu-header"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":2,"resourceType":"microsoft.cognitiveservices/accounts","metricScope":0,"resourceIds":["{CogServicesResource}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--AzureOpenAIProvisionedManagedUtilizationV2","aggregation":4,"splitBy":"ModelDeploymentName"},{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--AzureOpenAIProvisionedManagedUtilizationV2","aggregation":3,"splitBy":"ModelDeploymentName"}],"title":"PTU Utilization V2 (%) — Max + Avg by Deployment","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-ptu-utilization"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":2,"resourceType":"microsoft.cognitiveservices/accounts","metricScope":0,"resourceIds":["{CogServicesResource}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--AzureOpenAIProvisionedManagedUtilizationV2","aggregation":4,"splitBy":"StreamType"}],"title":"PTU Utilization V2 (%) — Streaming vs. Non-Streaming","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-ptu-streamtype"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":2,"resourceType":"microsoft.cognitiveservices/accounts","metricScope":0,"resourceIds":["{CogServicesResource}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--ActiveTokens","aggregation":4,"splitBy":"ModelDeploymentName"},{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--ActiveTokens","aggregation":3,"splitBy":"ModelDeploymentName"}],"title":"Active Tokens — PTU Consumption Proxy (Max + Avg) by Deployment","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-ptu-active-tokens"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":2,"resourceType":"microsoft.cognitiveservices/accounts","metricScope":0,"resourceIds":["{CogServicesResource}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--AzureOpenAIRequests","aggregation":1,"splitBy":"IsSpillover"}],"title":"Spillover Requests — PTU Overflow to Spillover Pool","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-ptu-spillover"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":2,"resourceType":"microsoft.cognitiveservices/accounts","metricScope":0,"resourceIds":["{CogServicesResource}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--AzureOpenAIRequests","aggregation":1,"splitBy":"StatusCode"}],"title":"Requests by Status Code by Deployment (filter StatusCode=429 in Metrics Explorer)","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-ptu-429"}]},"conditionalVisibility":{"parameterName":"tab","comparison":"isEqualTo","value":"ptu"},"name":"group-ptu"},{"type":12,"content":{"version":"NotebookGroup/1.0","groupType":"editable","items":[{"type":1,"content":{"json":"## Content Safety\nMonitors Azure OpenAI content filtering and Responsible AI telemetry. Split by `Category` and `Severity` dimensions for incident investigation."},"name":"safety-header"},{"type":3,"content":{"version":"KqlItem/1.0","query":"AzureMetrics\n| where MetricName in ('RAITotalRequests','RAIHarmfulRequests','RAIRejectedRequests','RAIAbusiveUsersCount')\n| summarize Total = sum(Total) by MetricName\n| project Category = case(MetricName == 'RAITotalRequests', 'Total Volume', MetricName == 'RAIHarmfulRequests', 'Harmful Volume', MetricName == 'RAIRejectedRequests', 'Blocked Volume', MetricName == 'RAIAbusiveUsersCount', 'Abusive Users', MetricName), Total","size":3,"noDataMessage":"No Content Safety events detected in the selected time range.","title":"Content Safety Breakdown","queryType":0,"resourceType":"microsoft.operationalinsights/workspaces","crossComponentResources":["{LogAnalyticsWorkspace}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","visualization":"piechart"},"conditionalVisibility":{"parameterName":"LogAnalyticsWorkspace","comparison":"isNotEqualTo","value":""},"customWidth":"100","name":"kpi-rai-piechart"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":3,"resourceType":"microsoft.cognitiveservices/accounts","metricScope":0,"resourceIds":["{CogServicesResource}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--RAIHarmfulRequests","aggregation":1,"splitBy":"Category"}],"title":"Harmful Volume by Category","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-rai-harmful-category"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":3,"resourceType":"microsoft.cognitiveservices/accounts","metricScope":0,"resourceIds":["{CogServicesResource}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--RAIHarmfulRequests","aggregation":1,"splitBy":"Severity"}],"title":"Harmful Volume by Severity","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-rai-harmful-severity"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":3,"resourceType":"microsoft.cognitiveservices/accounts","metricScope":0,"resourceIds":["{CogServicesResource}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--RAIRejectedRequests","aggregation":1,"splitBy":"Category"}],"title":"Blocked Volume by Category","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-rai-blocked-category"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":2,"resourceType":"microsoft.cognitiveservices/accounts","metricScope":0,"resourceIds":["{CogServicesResource}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--RAISystemEvent","aggregation":1,"splitBy":"EventType"}],"title":"RAI System Events by EventType","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-rai-system-events"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":2,"resourceType":"microsoft.cognitiveservices/accounts","metricScope":0,"resourceIds":["{CogServicesResource}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--ContentSafetyImageAnalyzeRequestCount","aggregation":1},{"namespace":"microsoft.cognitiveservices/accounts","metric":"microsoft.cognitiveservices/accounts--ContentSafetyTextAnalyzeRequestCount","aggregation":1}],"title":"Content Safety — Image + Text Moderation Call Volume","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-content-safety-moderation"}]},"conditionalVisibility":{"parameterName":"tab","comparison":"isEqualTo","value":"safety"},"name":"group-safety"},{"type":12,"content":{"version":"NotebookGroup/1.0","groupType":"editable","items":[{"type":1,"content":{"json":"## AI Agents — Azure AI Foundry Projects\n\n> **Preview:** AI Agents metrics are sourced from `Microsoft.CognitiveServices/accounts/projects`. These metrics are currently in Preview and are **not exportable** via Diagnostic Settings.\n\nFoundry Project resources are **auto-derived** from the parent Cognitive Services accounts selected above — no additional resource picker is required.\n\n> If no data appears, ensure your Azure AI Foundry Project resources exist under the selected Cognitive Services accounts and that agent workloads have been executed within the selected time range."},"name":"agents-header"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":3,"resourceType":"microsoft.cognitiveservices/accounts/projects","metricScope":0,"resourceIds":["{FoundryProjectResources}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts/projects","metric":"microsoft.cognitiveservices/accounts/projects--AgentRuns","aggregation":1,"splitBy":"RunStatus"}],"title":"Agent Runs by Status","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-agent-runs-status"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":3,"resourceType":"microsoft.cognitiveservices/accounts/projects","metricScope":0,"resourceIds":["{FoundryProjectResources}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts/projects","metric":"microsoft.cognitiveservices/accounts/projects--AgentResponses","aggregation":1,"splitBy":"ResponseStatus"}],"title":"Agent Responses by Response Status","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-agent-responses-status"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":2,"resourceType":"microsoft.cognitiveservices/accounts/projects","metricScope":0,"resourceIds":["{FoundryProjectResources}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts/projects","metric":"microsoft.cognitiveservices/accounts/projects--AgentInputTokens","aggregation":1,"splitBy":"ModelName"},{"namespace":"microsoft.cognitiveservices/accounts/projects","metric":"microsoft.cognitiveservices/accounts/projects--AgentOutputTokens","aggregation":1,"splitBy":"ModelName"}],"title":"Agent Input + Output Tokens by Model","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-agent-tokens"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":3,"resourceType":"microsoft.cognitiveservices/accounts/projects","metricScope":0,"resourceIds":["{FoundryProjectResources}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts/projects","metric":"microsoft.cognitiveservices/accounts/projects--AgentToolCalls","aggregation":1,"splitBy":"ToolName"}],"title":"Agent Tool Calls by Tool Name","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-agent-tool-calls"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":2,"resourceType":"microsoft.cognitiveservices/accounts/projects","metricScope":0,"resourceIds":["{FoundryProjectResources}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts/projects","metric":"microsoft.cognitiveservices/accounts/projects--AgentThreads","aggregation":1,"splitBy":"EventType"}],"title":"Agent Threads by EventType","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-agent-threads"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":2,"resourceType":"microsoft.cognitiveservices/accounts/projects","metricScope":0,"resourceIds":["{FoundryProjectResources}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts/projects","metric":"microsoft.cognitiveservices/accounts/projects--AgentMessages","aggregation":1,"splitBy":"EventType"}],"title":"Agent User Messages by EventType","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-agent-messages"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":3,"resourceType":"microsoft.cognitiveservices/accounts/projects","metricScope":0,"resourceIds":["{FoundryProjectResources}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts/projects","metric":"microsoft.cognitiveservices/accounts/projects--AgentRuns","aggregation":1,"splitBy":"ModelName"}],"title":"Agent Runs by Model Name","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-agent-runs-model"},{"type":10,"content":{"version":"MetricsItem/2.0","size":0,"chartType":3,"resourceType":"microsoft.cognitiveservices/accounts/projects","metricScope":0,"resourceIds":["{FoundryProjectResources}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","metrics":[{"namespace":"microsoft.cognitiveservices/accounts/projects","metric":"microsoft.cognitiveservices/accounts/projects--AgentUsageIndexedFiles","aggregation":1,"splitBy":"Status"}],"title":"Agent Indexed Files (Vector Store) by Status — split VectorStoreId for drill-down","showOpenInMetricsExplorer":true},"customWidth":"50","name":"chart-agent-indexed-files"}]},"conditionalVisibility":{"parameterName":"tab","comparison":"isEqualTo","value":"agents"},"name":"group-agents"},{"type":12,"content":{"version":"NotebookGroup/1.0","groupType":"editable","items":[{"type":1,"content":{"json":"## Logs & Diagnostics\nKQL-based deep diagnostics using Azure Monitor Log Analytics."},"name":"logs-header"},{"type":1,"content":{"json":"## Log Analytics Workspace Required\n\nThis tab requires a **Log Analytics Workspace** with Diagnostic Settings configured on your Azure AI / Cognitive Services resources.\n\n**To configure:**\n1. Navigate to your Cognitive Services resource → **Diagnostic settings**\n2. Add a diagnostic setting targeting your Log Analytics Workspace\n3. Enable log categories: `Audit`, `RequestResponse`, `Trace`\n4. Return here and select your Log Analytics Workspace in the **parameter bar above**\n\n> 📖 [Configure Diagnostic Settings — Microsoft Docs](https://learn.microsoft.com/en-us/azure/azure-monitor/essentials/create-diagnostic-settings)"},"conditionalVisibility":{"parameterName":"LogAnalyticsWorkspace","comparison":"isEqualTo","value":""},"showInEditMode":true,"name":"logs-no-law-message"},{"type":3,"content":{"version":"KqlItem/1.0","query":"AzureMetrics\n| where ResourceProvider =~ 'MICROSOFT.COGNITIVESERVICES'\n| where MetricName in ('AzureOpenAIRequests','ModelRequests','TotalCalls')\n| summarize Total = sum(Total) by bin(TimeGenerated, 15m), MetricName\n| render timechart","size":0,"title":"Request Volume Over Time by Metric","queryType":0,"resourceType":"microsoft.operationalinsights/workspaces","crossComponentResources":["{LogAnalyticsWorkspace}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","visualization":"timechart"},"conditionalVisibility":{"parameterName":"LogAnalyticsWorkspace","comparison":"isNotEqualTo","value":""},"customWidth":"50","name":"kql-request-volume"},{"type":3,"content":{"version":"KqlItem/1.0","query":"AzureMetrics\n| where ResourceProvider =~ 'MICROSOFT.COGNITIVESERVICES'\n| where MetricName in ('TokenTransaction','ProcessedPromptTokens','GeneratedTokens')\n| summarize Total = sum(Total) by bin(TimeGenerated, 15m), MetricName\n| render timechart","size":0,"title":"Token Volume Over Time (Prompt + Completion)","queryType":0,"resourceType":"microsoft.operationalinsights/workspaces","crossComponentResources":["{LogAnalyticsWorkspace}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","visualization":"timechart"},"conditionalVisibility":{"parameterName":"LogAnalyticsWorkspace","comparison":"isNotEqualTo","value":""},"customWidth":"50","name":"kql-throttled-requests"},{"type":3,"content":{"version":"KqlItem/1.0","query":"AzureMetrics\n| where ResourceProvider =~ 'MICROSOFT.COGNITIVESERVICES'\n| where MetricName in ('AzureOpenAIAvailabilityRate','ModelAvailabilityRate')\n| summarize AvgRate = avg(Average) by bin(TimeGenerated, 15m), MetricName, Resource\n| render timechart","size":0,"title":"Availability Rate Over Time (%)","queryType":0,"resourceType":"microsoft.operationalinsights/workspaces","crossComponentResources":["{LogAnalyticsWorkspace}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","visualization":"timechart"},"conditionalVisibility":{"parameterName":"LogAnalyticsWorkspace","comparison":"isNotEqualTo","value":""},"customWidth":"50","name":"kql-latency-percentiles"},{"type":3,"content":{"version":"KqlItem/1.0","query":"AzureMetrics\n| where ResourceProvider =~ 'MICROSOFT.COGNITIVESERVICES'\n| where MetricName in ('AzureOpenAINormalizedTTFTInMS','NormalizedTimeToFirstToken')\n| summarize AvgLatencyMs = avg(Average), MaxLatencyMs = max(Maximum) by bin(TimeGenerated, 15m), MetricName\n| render timechart","size":0,"title":"Normalized Time to First Byte — Avg + Max (ms)","queryType":0,"resourceType":"microsoft.operationalinsights/workspaces","crossComponentResources":["{LogAnalyticsWorkspace}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","visualization":"timechart"},"conditionalVisibility":{"parameterName":"LogAnalyticsWorkspace","comparison":"isNotEqualTo","value":""},"customWidth":"50","name":"kql-top-errors"},{"type":3,"content":{"version":"KqlItem/1.0","query":"AzureMetrics\n| where ResourceProvider =~ 'MICROSOFT.COGNITIVESERVICES'\n| where MetricName == 'TokenTransaction'\n| summarize TotalTokens = sum(Total) by Resource, ResourceGroup\n| top 20 by TotalTokens desc","size":0,"title":"Top Resources by Token Consumption","queryType":0,"resourceType":"microsoft.operationalinsights/workspaces","crossComponentResources":["{LogAnalyticsWorkspace}"],"timeContext":{"durationMs":0},"timeContextFromParameter":"TimeRange","visualization":"table","gridSettings":{"formatters":[{"columnMatch":"TotalTokens","formatter":4,"formatOptions":{"palette":"blue"}}],"filter":true,"sortBy":[{"itemKey":"TotalTokens","sortOrder":2}]}},"conditionalVisibility":{"parameterName":"LogAnalyticsWorkspace","comparison":"isNotEqualTo","value":""},"customWidth":"50","name":"kql-token-by-operation"}]},"conditionalVisibility":{"parameterName":"tab","comparison":"isEqualTo","value":"logs"},"name":"group-logs"},{"type":12,"content":{"version":"NotebookGroup/1.0","groupType":"editable","items":[{"type":1,"content":{"json":"## Inventory\nAzure Resource Graph-driven inventory of all Cognitive Services and Azure AI resources, model deployments, private endpoints, and Diagnostic Settings posture."},"name":"inventory-header"},{"type":3,"content":{"version":"KqlItem/1.0","query":"Resources\n| where type =~ 'microsoft.cognitiveservices/accounts'\n| project ResourceName = name, ResourceGroup = resourceGroup, Kind = tostring(kind), SKU = tostring(sku.name), Location = location, Endpoint = tostring(properties.endpoint), CustomDomain = tostring(properties.customSubDomainName), PublicAccess = tostring(properties.publicNetworkAccess), ProvisioningState = tostring(properties.provisioningState), SubscriptionId = subscriptionId\n| order by ResourceName asc","size":0,"title":"Cognitive Services Resources","queryType":1,"resourceType":"microsoft.resources/subscriptions","crossComponentResources":["{Subscription}"],"visualization":"table","gridSettings":{"formatters":[{"columnMatch":"ProvisioningState","formatter":18,"formatOptions":{"thresholdsOptions":"colors","thresholdsGrid":[{"operator":"==","thresholdValue":"Succeeded","representation":"green","text":"{0}{1}"},{"operator":"Default","thresholdValue":null,"representation":"yellow","text":"{0}{1}"}]}},{"columnMatch":"PublicAccess","formatter":18,"formatOptions":{"thresholdsOptions":"colors","thresholdsGrid":[{"operator":"==","thresholdValue":"Enabled","representation":"red","text":"{0}{1}"},{"operator":"Default","thresholdValue":null,"representation":"green","text":"{0}{1}"}]}}],"filter":true}},"name":"table-cog-resources"},{"type":3,"content":{"version":"KqlItem/1.0","query":"Resources\n| where type =~ 'microsoft.cognitiveservices/accounts/deployments'\n| project DeploymentName = name, ParentResource = tostring(split(id, '/')[8]), ResourceGroup = resourceGroup, Model = tostring(properties.model.name), Version = tostring(properties.model.version), Format = tostring(properties.model.format), SKU = tostring(sku.name), Capacity = tostring(sku.capacity), ScaleType = tostring(properties.scaleSettings.scaleType), ProvisioningState = tostring(properties.provisioningState)\n| order by ParentResource asc, DeploymentName asc","size":0,"title":"Model Deployments","queryType":1,"resourceType":"microsoft.resources/subscriptions","crossComponentResources":["{Subscription}"],"visualization":"table","gridSettings":{"formatters":[{"columnMatch":"ProvisioningState","formatter":18,"formatOptions":{"thresholdsOptions":"colors","thresholdsGrid":[{"operator":"==","thresholdValue":"Succeeded","representation":"green","text":"{0}{1}"},{"operator":"Default","thresholdValue":null,"representation":"yellow","text":"{0}{1}"}]}}],"filter":true}},"name":"table-model-deployments"},{"type":3,"content":{"version":"KqlItem/1.0","query":"Resources\n| where type =~ 'microsoft.network/privateendpoints'\n| mv-expand connection = properties.privateLinkServiceConnections\n| where tostring(connection.properties.privateLinkServiceId) contains 'cognitiveservices'\n| project PrivateEndpoint = name, ResourceGroup = resourceGroup, Location = location, LinkedResource = tostring(split(tostring(connection.properties.privateLinkServiceId), '/')[8]), ConnectionState = tostring(connection.properties.privateLinkServiceConnectionState.status)\n| order by LinkedResource asc","size":0,"title":"Private Endpoints — AI / Cognitive Services","queryType":1,"resourceType":"microsoft.resources/subscriptions","crossComponentResources":["{Subscription}"],"visualization":"table","gridSettings":{"formatters":[{"columnMatch":"ConnectionState","formatter":18,"formatOptions":{"thresholdsOptions":"colors","thresholdsGrid":[{"operator":"==","thresholdValue":"Approved","representation":"green","text":"{0}{1}"},{"operator":"Default","thresholdValue":null,"representation":"yellow","text":"{0}{1}"}]}}],"filter":true}},"name":"table-private-endpoints"},{"type":3,"content":{"version":"KqlItem/1.0","query":"Resources\n| where type =~ 'microsoft.cognitiveservices/accounts/deployments'\n| project DeploymentName = name, ParentAccount = tostring(split(id, '/')[8]), ResourceGroup = resourceGroup, Model = tostring(properties.model.name), Version = tostring(properties.model.version), Format = tostring(properties.model.format), SKU = tostring(sku.name), Capacity = tostring(sku.capacity), ScaleType = tostring(properties.scaleSettings.scaleType), ProvisioningState = tostring(properties.provisioningState)\n| order by ParentAccount asc, DeploymentName asc","size":0,"title":"Model Deployments — Full Detail","queryType":1,"resourceType":"microsoft.resources/subscriptions","crossComponentResources":["{Subscription}"],"visualization":"table","gridSettings":{"formatters":[{"columnMatch":"ProvisioningState","formatter":18,"formatOptions":{"thresholdsOptions":"colors","thresholdsGrid":[{"operator":"==","thresholdValue":"Succeeded","representation":"green","text":"{0}{1}"},{"operator":"Default","thresholdValue":null,"representation":"yellow","text":"{0}{1}"}]}}],"filter":true}},"name":"table-diagnostic-settings"}]},"conditionalVisibility":{"parameterName":"tab","comparison":"isEqualTo","value":"inventory"},"name":"group-inventory"}],"$schema":"https://github.com/Microsoft/Application-Insights-Workbooks/blob/master/schema/workbook.json"}
